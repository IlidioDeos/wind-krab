# ── Required ──────────────────────────────────────────────────────────────────
# OpenRouter API key (get one at https://openrouter.ai/keys)
# Default model is claude-haiku-4-5 via OpenRouter.
# To change the model edit config/openclaw.json → agents.defaults.model.primary
OPENROUTER_API_KEY=sk-or-...

# ── Optional: gateway ─────────────────────────────────────────────────────────
OPENCLAW_GATEWAY_TOKEN=dev-token-change-me
TZ=UTC

# ── Optional: Telegram ────────────────────────────────────────────────────────
# 1. Open @BotFather on Telegram
# 2. Send /newbot and follow the instructions
# 3. Paste the token below — the bot will be available as soon as the container starts
#
# TELEGRAM_BOT_TOKEN=123456789:AAF...

# ── Optional: Slack (Socket Mode) ────────────────────────────────────────────
# 1. Go to https://api.slack.com/apps → Create New App → From scratch
# 2. Enable Socket Mode → copy the App-Level Token (xapp-...)
# 3. Add a Bot Token Scope (chat:write, im:history, im:read) → Install to workspace → copy xoxb-...
# 4. Under "Event Subscriptions" → Subscribe to bot events: message.im
#
# SLACK_APP_TOKEN=xapp-1-...
# SLACK_BOT_TOKEN=xoxb-...
