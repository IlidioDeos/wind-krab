{
  "name": "knowledge-broker",
  "version": "1.0.0",
  "description": "Cross-Session Knowledge Broker for OpenClaw",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && cp openclaw.plugin.json dist/openclaw.plugin.json",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.32.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "peerDependencies": {
    "openclaw": "*"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.16.0"
  }
}
